---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found">
  <section class="flex min-h-[70vh] flex-col items-center justify-center px-6 text-center">
    <h1 class="font-heading text-6xl font-bold text-text-primary sm:text-8xl">404</h1>
    <p id="msg-404" class="mt-4 text-lg text-text-secondary">This page does not exist.</p>
    <a
      id="link-404"
      href="/"
      class="mt-8 rounded-lg border border-border px-5 py-2.5 text-sm font-medium text-text-secondary transition-colors hover:border-accent hover:text-accent"
    >
      Back to home
    </a>
  </section>

  <script>
    const isIt = window.location.pathname.startsWith('/it');
    if (isIt) {
      const msg = document.getElementById('msg-404');
      const link = document.getElementById('link-404');
      if (msg) msg.textContent = 'Questa pagina non esiste.';
      if (link) {
        link.textContent = 'Torna alla home';
        link.setAttribute('href', '/it/');
      }
    }
  </script>
</BaseLayout>
