---
import BaseLayout from '../layouts/BaseLayout.astro';
import { translations } from '../i18n/translations';
---

<BaseLayout title="404" description="Page not found">
  <Fragment slot="head">
    <!-- Sets html.is-it before body parses, so the correct language renders with no flash.
         Needed because CloudFront serves this same static 404.html for every locale. -->
    <script is:inline>
      if (location.pathname.startsWith('/it')) {
        document.documentElement.classList.add('is-it');
      }
    </script>
  </Fragment>

  <section class="flex min-h-[70vh] flex-col items-center justify-center px-6 text-center">
    <h1 class="font-heading text-6xl font-bold text-text-primary sm:text-8xl">404</h1>

    <div class="lang-en">
      <p class="mt-4 text-lg text-text-secondary">{translations.en['404.message']}</p>
      <a
        href="/"
        class="mt-8 rounded-lg border border-border px-5 py-2.5 text-sm font-medium text-text-secondary transition-colors hover:border-accent hover:text-accent"
      >
        {translations.en['404.back']}
      </a>
    </div>

    <div class="lang-it">
      <p class="mt-4 text-lg text-text-secondary">{translations.it['404.message']}</p>
      <a
        href="/it/"
        class="mt-8 rounded-lg border border-border px-5 py-2.5 text-sm font-medium text-text-secondary transition-colors hover:border-accent hover:text-accent"
      >
        {translations.it['404.back']}
      </a>
    </div>
  </section>

  <style>
    /* Default (no JS / no locale class): show English, the site's default locale. */
    .lang-en {
      display: contents;
    }
    .lang-it {
      display: none;
    }
    :global(html.is-it) .lang-en {
      display: none;
    }
    :global(html.is-it) .lang-it {
      display: contents;
    }
  </style>
</BaseLayout>
