---
import ProjectCard from './ProjectCard.astro';
import type { Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const projects = [
  {
    title: 'cloudrift',
    description: t('projects.cloudrift.description'),
    tags: ['Open Source', 'AWS', 'TypeScript', 'DDD'],
    href: 'https://github.com/elleVas/cloudrift',
  },
  {
    title: 'cloudrift-cdk-test',
    description: t('projects.cloudrift-cdk-test.description'),
    tags: ['AWS CDK', 'Testing', 'IaC', 'TypeScript'],
    href: 'https://github.com/elleVas/cloudrift-cdk-test',
  },
  {
    title: 'ellevas.dev',
    description: t('projects.ellevas.description'),
    tags: ['Astro', 'AWS CDK', 'Tailwind', 'Bun'],
    href: 'https://github.com/elleVas/ellevas-site',
  },
];
---

<section id="projects" class="px-6 py-16">
  <div data-animate class="animate-target mx-auto max-w-[var(--width-content)]">
    <h2 class="text-center font-heading text-2xl font-semibold sm:text-3xl">
      <span class="bg-gradient-to-br from-text-primary to-text-heading bg-clip-text text-transparent">
        {t('projects.title')}
      </span>
    </h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </div>
</section>
